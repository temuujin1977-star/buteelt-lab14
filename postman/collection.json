{
  "info": {
    "_postman_id": "88b7f6be-8211-4f5c-a7a3-1b84c9ef1c14",
    "name": "F.CSM311 - Lab14 Task API",
    "description": "Integration & API testing collection for Bie Daalt 14.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Happy GET - health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('service is lab14-api', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.ok).to.eql(true);",
                  "  pm.expect(json.service).to.eql('lab14-api');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Happy GET - tasks list",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tasks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('body is an array', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST create - create task and save id",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Newman chained task\",\n  \"status\": \"todo\"\n}"
            },
            "url": "{{baseUrl}}/tasks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('created task has id and expected title', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.expect(json.title).to.eql('Newman chained task');",
                  "  pm.environment.set('createdTaskId', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET by id - chained task",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tasks/{{createdTaskId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('id matches environment variable', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.eql(Number(pm.environment.get('createdTaskId')));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "PUT update - chained task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Lab14 task\",\n  \"status\": \"doing\"\n}"
            },
            "url": "{{baseUrl}}/tasks/{{createdTaskId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('task is updated', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.title).to.eql('Updated Lab14 task');",
                  "  pm.expect(json.status).to.eql('doing');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH update - status only",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            },
            "url": "{{baseUrl}}/tasks/{{createdTaskId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('status changed to done', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('done');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE - chained task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/tasks/{{createdTaskId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 204', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Error case - task not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tasks/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "pm.test('error message exists', function () {",
                  "  pm.expect(pm.response.json().error).to.eql('Task not found');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Error case - validation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"todo\"\n}"
            },
            "url": "{{baseUrl}}/tasks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('validation message exists', function () {",
                  "  pm.expect(pm.response.json().error).to.eql('title is required');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
